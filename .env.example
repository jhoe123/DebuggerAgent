# =============================================================================
# PatchPilot — environment template
# Copy to .env and fill in. NEVER commit .env (see .gitignore).
# =============================================================================

# --- Google Cloud / Gemini (Vertex AI / Gemini Enterprise Agent Platform) ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Gemini 3.x models are served from the "global" location (not us-central1).
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=true
# gemini-3.5-flash (fast) is the default; gemini-3.1-pro-preview also works (slower, deeper).
GEMINI_MODEL=gemini-3.5-flash
# Region used only for Cloud Run deploy (must be a real region, not "global").
CLOUD_RUN_REGION=us-central1

# --- Dynatrace ---
# Tenant base URL, e.g. https://abc12345.apps.dynatrace.com
DT_ENVIRONMENT=https://your-tenant.apps.dynatrace.com
# Platform token with scopes: read problems, read logs, DQL/Grail read (see README §3).
DT_PLATFORM_TOKEN=dt0s16.XXXXXXXX.XXXXXXXXXXXXXXXX
DT_MCP_DISABLE_TELEMETRY=true
# T3 only: classic API token (dt0c01...) with 'Ingest OpenTelemetry traces' scope,
# used by demo_app/scripts/run_demo.ps1 to export the seeded exception to Dynatrace.
DT_API_TOKEN=
# The MCP server needs Node >= 20.17 (ideally 22/24). If your system Node is older,
# point this at a newer node.exe used only to spawn the MCP server.
MCP_NODE_BIN=
# Only if a TLS-intercepting AV/proxy (e.g. Avast) breaks Node HTTPS: path to a CA
# bundle (export of the Windows root store). Passed through to the spawned MCP server.
NODE_EXTRA_CA_CERTS=

# --- Backend server ---
PORT=8080
# Test Console + auto-remediation/instrument-apply (backend git-resets/builds/runs demo_app).
# Defaults ON locally; set to "false" to disable. The hosted Cloud Run image pins it false.
ENABLE_TEST_CONSOLE=true
# Start with a clean problem list: only surface problems detected AFTER the server
# starts (a fresh boot shows nothing; new incidents appear as they happen).
# Defaults ON; set to "false" to show the full 30-day Dynatrace problem window.
CLEAR_ISSUES_ON_START=true
# Absolute or relative path the read_source tool is allowed to read (the demo app).
SOURCE_ROOT=./demo_app
# Where approved patches are written (branch/file only — never merged/deployed).
PATCH_OUTPUT_DIR=./.patches

# --- Remediation pipeline runner ---
# "local"      — apply→test→build→deploy run in-process (needs ENABLE_TEST_CONSOLE=true).
# "cloudbuild" — deploy demo_app to Cloud Run via Cloud Build (hosted path). See docs/cloud-pipeline.md.
PIPELINE_MODE=local
# Cloud Build runner settings (used only when PIPELINE_MODE=cloudbuild):
# GCS bucket for the uploaded build source (defaults to <project>_cloudbuild).
CLOUD_BUILD_SOURCE_BUCKET=
# Artifact Registry Docker repo (in CLOUD_RUN_REGION) the image is pushed to.
ARTIFACT_REGISTRY_REPO=patchpilot
# Cloud Run service name the demo_app storefront deploys to.
DEMO_RUN_SERVICE=checkout-demo

# --- Slack notifications (optional) ---
# If set, a background poller posts a single, consolidated "rolling digest" of all
# active bugs to this Slack Incoming Webhook (re-posted only when the bug set changes
# — no per-occurrence spam). Leave empty to disable. SECRET: never commit a real value.
SLACK_WEBHOOK_URL=
# How often the poller checks Dynatrace for new/changed bugs (Go duration, default 60s).
SLACK_POLL_INTERVAL=60s

# --- Git source (optional): clone a repo, branch per fix, merge on confirm ---
# Gate for clone/branch/commit/merge/push. Defaults ON; set to "false" to disable.
# Harmless until a repo is configured (and pushing still needs a token + push enabled).
# Requires the `git` binary on PATH (the Docker image installs it).
ENABLE_GIT_SOURCE=true
# HTTPS clone URL of the repo PatchPilot patches (no embedded credentials).
# Defaults to the published ShopFlow demo repo (the one PatchPilot was tested against).
GIT_SOURCE_REPO_URL=https://github.com/jhoe123/patchpilot-demo-app.git
# SECRET: HTTPS personal access token for push/merge. NEVER commit a real value.
# Leave empty for local-only (clone/branch/commit/merge without pushing).
GIT_SOURCE_TOKEN=
# Integration branch fixes merge into when confirmed.
GIT_SOURCE_WORKING_BRANCH=patchpilot
# Prefix for the per-fix branches (one branch per problem).
GIT_SOURCE_BRANCH_PREFIX=patchpilot/fix-
# Create an isolated branch per fix (recommended).
GIT_SOURCE_BRANCH_PER_FIX=true
# On confirm, merge the fix branch into the working branch then delete it. Default on.
GIT_SOURCE_AUTO_MERGE=true
# Permission gate: push branches/merges to the remote. Default OFF (local-only).
GIT_SOURCE_PUSH_ENABLED=false
# Commit identity used for fix commits and merges.
GIT_SOURCE_COMMIT_NAME=PatchPilot
GIT_SOURCE_COMMIT_EMAIL=patchpilot@local
# Where the repo is cloned (defaults to <PATCH_OUTPUT_DIR>/gitsrc).
GIT_SOURCE_CLONE_DIR=

# --- Frontend (Vite) ---
# Base URL the React app calls. Leave empty to use same-origin (Cloud Run).
VITE_API_BASE_URL=http://localhost:8080
