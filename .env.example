# =============================================================================
# DebuggerAgent — environment template
# Copy to .env and fill in. NEVER commit .env (see .gitignore).
# =============================================================================

# --- Google Cloud / Gemini (Vertex AI / Gemini Enterprise Agent Platform) ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Gemini 3.x models are served from the "global" location (not us-central1).
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=true
# gemini-3.5-flash (fast) is the default; gemini-3.1-pro-preview also works (slower, deeper).
GEMINI_MODEL=gemini-3.5-flash
# Region used only for Cloud Run deploy (must be a real region, not "global").
CLOUD_RUN_REGION=us-central1

# --- Dynatrace ---
# Tenant base URL, e.g. https://abc12345.apps.dynatrace.com
DT_ENVIRONMENT=https://your-tenant.apps.dynatrace.com
# Platform token with scopes: read problems, read logs, DQL/Grail read (see README §3).
DT_PLATFORM_TOKEN=dt0s16.XXXXXXXX.XXXXXXXXXXXXXXXX
DT_MCP_DISABLE_TELEMETRY=true
# T3 only: classic API token (dt0c01...) with 'Ingest OpenTelemetry traces' scope,
# used by demo_app/scripts/run_demo.ps1 to export the seeded exception to Dynatrace.
DT_API_TOKEN=
# The MCP server needs Node >= 20.17 (ideally 22/24). If your system Node is older,
# point this at a newer node.exe used only to spawn the MCP server.
MCP_NODE_BIN=
# Only if a TLS-intercepting AV/proxy (e.g. Avast) breaks Node HTTPS: path to a CA
# bundle (export of the Windows root store). Passed through to the spawned MCP server.
NODE_EXTRA_CA_CERTS=

# --- Backend server ---
PORT=8080
# Test Console + auto-remediation/instrument-apply (backend git-resets/builds/runs demo_app).
# Defaults ON locally; set to "false" to disable. The hosted Cloud Run image pins it false.
ENABLE_TEST_CONSOLE=true
# Absolute or relative path the read_source tool is allowed to read (the demo app).
SOURCE_ROOT=./demo_app
# Where approved patches are written (branch/file only — never merged/deployed).
PATCH_OUTPUT_DIR=./.patches

# --- Slack notifications (optional) ---
# If set, a background poller posts a single, consolidated "rolling digest" of all
# active bugs to this Slack Incoming Webhook (re-posted only when the bug set changes
# — no per-occurrence spam). Leave empty to disable. SECRET: never commit a real value.
SLACK_WEBHOOK_URL=
# How often the poller checks Dynatrace for new/changed bugs (Go duration, default 60s).
SLACK_POLL_INTERVAL=60s

# --- Frontend (Vite) ---
# Base URL the React app calls. Leave empty to use same-origin (Cloud Run).
VITE_API_BASE_URL=http://localhost:8080
